# Скопируй этот файл в .env и заполни значения для локальной разработки
# Для Render — переменные вводятся в Dashboard, этот файл не нужен

# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Строка подключения к PostgreSQL (Supabase)
# Формат: postgresql://postgres:ПАРОЛЬ@db.xxxx.supabase.co:5432/postgres
# Если НЕ указана — бот использует SQLite локально (sov.db)
DATABASE_URL=

# URL для webhook (только для продакшена на Render)
# Если НЕ указан — бот работает в режиме polling (удобно локально)
WEBHOOK_HOST=

# Порт для webhook-сервера (Render сам устанавливает PORT)
PORT=8080
